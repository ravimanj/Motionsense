<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Camera preview — full screen -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Skeleton overlay — same size as preview -->
    <com.motionsense.ai.ui.SkeletonOverlayView
        android:id="@+id/skeletonOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ===== TOP BAR ===== -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_overlay_dark"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="44dp"
        android:paddingBottom="14dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvExerciseName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Bicep Curl"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/tvConnectionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● Connecting…"
            android:textSize="12sp"
            android:textColor="@color/status_warning"
            android:layout_marginEnd="12dp" />

        <!--
            Use androidx.appcompat.widget.AppCompatButton with a plain drawable background
            so the text is guaranteed to render on all API levels and themes.
        -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnStop"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="■ Stop"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_pill_purple"
            android:stateListAnimator="@null"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:minWidth="0dp"
            android:minHeight="0dp" />

    </LinearLayout>

    <!-- ===== COUNTER PANEL (top-left) ===== -->
    <LinearLayout
        android:id="@+id/counterPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_overlay_dark"
        android:padding="14dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tvCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="72sp"
            android:textStyle="bold"
            android:lineSpacingExtra="0dp"
            android:includeFontPadding="false"
            android:textColor="@color/accent_green" />

        <TextView
            android:id="@+id/tvTargetLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="/ 10 REPS"
            android:textSize="13sp"
            android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/tvStage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="READY"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/bg_primary"
            android:background="@drawable/bg_pill_green"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp" />

    </LinearLayout>

    <!-- ===== FEEDBACK BAR (bottom) ===== -->
    <TextView
        android:id="@+id/tvFeedback"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:gravity="center"
        android:text="Connecting to AI server…"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:background="@color/feedback_good"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ===== PROGRESS BAR (sits just above feedback bar) ===== -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="0dp"
        android:layout_height="6dp"
        android:progressTint="@color/accent_green"
        android:progressBackgroundTint="@color/bg_surface"
        android:max="10"
        android:progress="0"
        app:layout_constraintBottom_toTopOf="@id/metricsRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ===== METRICS ROW (above feedback bar) ===== -->
    <LinearLayout
        android:id="@+id/metricsRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingBottom="4dp"
        app:layout_constraintBottom_toTopOf="@id/tvFeedback"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- CORRECT -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="68dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_overlay_dark"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp">
            <TextView
                android:id="@+id/tvCorrectReps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/status_good" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CORRECT"
                android:textSize="10sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <!-- ERRORS -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="68dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_overlay_dark"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp">
            <TextView
                android:id="@+id/tvIncorrectReps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/status_error" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ERRORS"
                android:textSize="10sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <!-- ACCURACY -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="68dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_overlay_dark"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp">
            <TextView
                android:id="@+id/tvAccuracy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/status_warning" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACCURACY"
                android:textSize="10sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <!-- ANGLE -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="68dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_overlay_dark"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp">
            <TextView
                android:id="@+id/tvAngle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0°"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/accent_purple" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ANGLE"
                android:textSize="10sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
