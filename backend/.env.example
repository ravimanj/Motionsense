# MotionSense AI — Environment Variables
# ----------------------------------------
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to git (it is already in .gitignore).

# ── SendGrid (used for OTP emails) ────────────────────────────────────────────
# WHY SendGrid? Render free tier blocks SMTP (port 587).
# SendGrid uses HTTPS (port 443) which works everywhere.
#
# Quick setup (free, 5 minutes):
#   1. Sign up: https://signup.sendgrid.com  (100 emails/day free)
#   2. Verify your sender email:
#      SendGrid Dashboard → Settings → Sender Authentication
#      → "Single Sender Verification" → add your email → click the verification link
#   3. Create an API key:
#      Settings → API Keys → Create API Key
#      → Restricted Access → enable "Mail Send" only → Create & View
#      → copy the key (starts with "SG.")
#   4. Paste both values below

SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM=your_verified_sender@gmail.com

# ── JWT secret key ─────────────────────────────────────────────────────────────
# Change this to a long random string in production.
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret-key
