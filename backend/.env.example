# MotionSense AI — Environment Variables
# ----------------------------------------
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to git (it is in .gitignore).

# Gmail SMTP credentials for OTP emails
# Step-by-step setup:
#   1. Sign in to your Google account
#   2. Enable 2-Step Verification: https://myaccount.google.com/security
#   3. Generate an App Password:   https://myaccount.google.com/apppasswords
#      - Select app: "Mail"  |  Select device: "Other (custom)" → name it "MotionSense"
#      - Click Generate → copy the 16-character password (spaces don't matter)
#   4. Paste below (remove the angle brackets)

GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASS=xxxx xxxx xxxx xxxx

# JWT secret key (change this to any long random string in production)
# You can generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret-key
